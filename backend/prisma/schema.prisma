generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  ROOT
  ADMIN // Administradores 
  NOTARYBOSS // Chefe de Cartório
  TECHNICAL // Técnico Judiciários
  LOGISTICS // Informalmente "roteiristas".
  DRIVER // Motoristas
  TRAINEE // Estagiários
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  phone          String
  streetNumber   Int?
  complement     String?
  notaryOfficeId String?
  addressId      String?
  userType       UserType

  Auth         Auth?
  NotaryOffice NotaryOffice? @relation(fields: [notaryOfficeId], references: [id])
  Address      Address?      @relation(fields: [addressId], references: [id])
}

model Auth {
  id       String @id @default(uuid())
  userId   String @unique
  password String

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Municipality {
  id             String @id @default(uuid())
  name           String
  code           String @unique
  notaryOfficeId String

  NotaryOffice NotaryOffice? @relation(fields: [notaryOfficeId], references: [id])
  VotingPlace  VotingPlace[]
}

model NotaryOffice {
  id           String  @id @default(uuid())
  zone         String
  name         String
  phone        String
  streetNumber Int?
  complement   String?
  addressId    String
  lat          Float?
  lng          Float?

  isTransmissionPoint Boolean @default(false)

  Address      Address        @relation(fields: [addressId], references: [id])
  User         User[]
  Municipality Municipality[]
  VotingPlace  VotingPlace[]

  @@index([isTransmissionPoint])
}

model VotingPlace {
  id             String   @id @default(uuid())
  code           Int      @unique
  name           String
  addressId      String
  municipalityId String
  streetNumber   Int?
  complement     String?
  sections       String[]
  voters         Int
  notaryOfficeId String
  lat            Float?
  lng            Float?

  transmitToVotingPlaceId  String?
  transmitToNotaryOfficeId String?

  isTransmissionPoint          Boolean @default(false)
  transmissionOperator         String?
  transmissionPointKit         String?
  transmissionPointKitPassword String?

  Address      Address      @relation(fields: [addressId], references: [id])
  Municipality Municipality @relation(fields: [municipalityId], references: [id])
  NotaryOffice NotaryOffice @relation(fields: [notaryOfficeId], references: [id], onDelete: Cascade)

  @@index([municipalityId])
  @@index([transmitToVotingPlaceId])
  @@index([transmitToNotaryOfficeId])
}

model Address {
  id           String @id @default(uuid())
  zipCode      String
  street       String
  neighborhood String
  city         String
  state        String
  country      String @default("Brasil")

  User         User[]
  VotingPlace  VotingPlace[]
  NotaryOffice NotaryOffice[]
}

model Routers {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now()) @db.Timestamp(3)
  routerData Json     @db.JsonB
}
